{
  "openapi": "3.0.3",
  "info": {
    "title": "Vue Blog API",
    "version": "2.1.0",
    "description": "Nuxt 4 + MySQL 个人博客 REST API"
  },
  "servers": [{ "url": "http://localhost:3000" }],
  "tags": [
    { "name": "文章", "description": "公开文章接口" },
    { "name": "搜索", "description": "Meilisearch / MySQL 搜索" },
    { "name": "认证", "description": "登录注册" },
    { "name": "评论", "description": "评论系统" },
    { "name": "上传", "description": "图片存储（local / 阿里云 / 七牛）" },
    { "name": "管理", "description": "后台管理 API" }
  ],
  "paths": {
    "/api/posts": {
      "get": {
        "summary": "文章列表",
        "tags": ["文章"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer" } },
          { "name": "keyword", "in": "query", "schema": { "type": "string" } },
          { "name": "orderBy", "in": "query", "schema": { "type": "string", "enum": ["latest", "popular"] } }
        ]
      }
    },
    "/api/posts/{slug}": {
      "get": {
        "summary": "文章详情",
        "tags": ["文章"],
        "parameters": [{ "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }]
      }
    },
    "/api/search": {
      "get": {
        "summary": "全文搜索（Meilisearch 优先）",
        "tags": ["搜索"],
        "parameters": [
          { "name": "keyword", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ]
      }
    },
    "/api/comments": {
      "get": { "summary": "评论列表", "tags": ["评论"] },
      "post": { "summary": "提交评论", "tags": ["评论"] }
    },
    "/api/auth/login": { "post": { "summary": "登录", "tags": ["认证"] } },
    "/api/auth/register": { "post": { "summary": "注册", "tags": ["认证"] } },
    "/api/auth/me": { "get": { "summary": "当前用户", "tags": ["认证"] } },
    "/api/auth/permissions": { "get": { "summary": "当前用户权限码", "tags": ["认证"] } },
    "/api/upload/image": { "post": { "summary": "图片上传", "tags": ["上传"] } },
    "/api/admin/posts": {
      "get": { "summary": "管理-文章列表", "tags": ["管理"] },
      "post": { "summary": "管理-创建文章", "tags": ["管理"] }
    },
    "/api/admin/posts/trash": { "get": { "summary": "管理-回收站", "tags": ["管理"] } },
    "/api/admin/posts/{id}/restore": { "post": { "summary": "管理-恢复文章", "tags": ["管理"] } },
    "/api/admin/posts/{id}/permanent": { "delete": { "summary": "管理-永久删除", "tags": ["管理"] } },
    "/api/admin/menus": { "get": { "summary": "动态菜单", "tags": ["管理"] } },
    "/api/admin/roles": { "get": { "summary": "角色权限列表", "tags": ["管理"] } },
    "/api/admin/roles/{role}": { "put": { "summary": "更新角色权限", "tags": ["管理"] } },
    "/api/admin/logs": { "get": { "summary": "操作日志", "tags": ["管理"] } },
    "/api/admin/search/reindex": { "post": { "summary": "重建 Meilisearch 索引", "tags": ["管理"] } }
  }
}
