# 站点公开配置
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_NAME=My Blog
NUXT_PUBLIC_SITE_DESCRIPTION=一个支持 SEO 的个人技术博客

# Google Analytics / 百度统计（也可在后台「站点设置」中配置）
# NUXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NUXT_PUBLIC_BAIDU_TONGJI_ID=your-baidu-site-id

# JWT 密钥（生产环境务必更换为随机长字符串）
JWT_SECRET=your-super-secret-jwt-key-change-me

# MySQL 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=blog
DB_PASSWORD=blog123
DB_NAME=blog_db

# Redis 缓存（可选：页面缓存 + 阅读量缓冲，不配置则使用内存）
# REDIS_URL=redis://localhost:6379

# Meilisearch 全文搜索（可选，不配置则回退 MySQL LIKE）
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=dev-master-key

# 文件存储：local | aliyun | qiniu | cloudinary（oss 等同于 aliyun）
STORAGE_DRIVER=local

# 阿里云 OSS（STORAGE_DRIVER=aliyun 时使用）
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_CDN_URL=https://cdn.example.com

# 七牛云（STORAGE_DRIVER=qiniu 时使用）
# QINIU_ACCESS_KEY=
# QINIU_SECRET_KEY=
# QINIU_BUCKET=your-bucket
# QINIU_DOMAIN=https://cdn.example.com

# Cloudinary（STORAGE_DRIVER=cloudinary 时使用）
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=blog/uploads
