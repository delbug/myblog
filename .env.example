# 站点公开配置
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_NAME=My Blog
NUXT_PUBLIC_SITE_DESCRIPTION=一个支持 SEO 的个人技术博客

# JWT 密钥（生产环境务必更换为随机长字符串）
JWT_SECRET=your-super-secret-jwt-key-change-me

# MySQL 数据库
DB_HOST=localhost

# Redis 缓存（可选，不配置则使用内存缓存）
# REDIS_URL=redis://localhost:6379

# OSS 配置（STORAGE_DRIVER=oss 时使用，当前回退本地）
# OSS_REGION=
# OSS_BUCKET=
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_CDN_URL=
DB_PORT=3306
DB_USER=blog
DB_PASSWORD=blog123
DB_NAME=blog_db
